{
  "name": "@load/electron",
  "version": "0.1.3",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "test": "echo 'no tests for electron wrapper'"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "electron": "30.5.1",
    "electron-builder": "^24.9.0"
  },
  "build": {
    "appId": "com.load.game",
    "productName": "Load",
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js"
    ],
    "extraResources": [
      {
        "from": "../web/dist",
        "to": "web-dist",
        "filter": [
          "**/*"
        ]
      }
    ],
    "linux": {
      "target": "AppImage"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    }
  }
}
